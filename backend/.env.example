# Database (optional — extension works locally without it)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/across

# ===== FREE OPTIONS (no credit card needed) =====

# Jina AI for embeddings — free tier, 1M tokens/month
# Sign up at https://jina.ai/embeddings
JINA_API_KEY=jina_your_key_here

# Groq for LLM chat — free tier, fast Llama 3 models
# Sign up at https://console.groq.com, get key at https://console.groq.com/keys
# No credit card needed for free tier
GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile  # (default) 131K context, best quality
# GROQ_MODEL=llama-3.1-8b-instant     # smaller, faster, still good

# Hugging Face for chat LLM — free inference API (may be blocked on some networks)
# Sign up at https://huggingface.co/join
# HF_API_TOKEN=hf_your_token_here

# ===== PAID OPTIONS =====
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3001
NODE_ENV=development
