# Database (optional — extension works locally without it)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/across

# Pick ONE embedding provider (free options available):
JINA_API_KEY=jina_your-key-here     # Jina AI: free tier, 1M tokens/month
# OPENAI_API_KEY=sk-your-key-here   # OpenAI: paid, best quality
# HF_API_TOKEN=hf_your-token-here   # Hugging Face: free inference API

# Anthropic for Claude chat (what you have):
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3001
NODE_ENV=development
