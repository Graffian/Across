# Database (optional — extension works locally without it)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/across

# ===== FREE OPTIONS (no credit card needed) =====

# Jina AI for embeddings — free tier, 1M tokens/month
# Sign up at https://jina.ai/embeddings
JINA_API_KEY=jina_your_key_here

# Hugging Face for chat LLM + embeddings — free inference API
# Sign up at https://huggingface.co/join, get token at https://huggingface.co/settings/tokens
# HF_API_TOKEN=hf_your_token_here
# HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3   # free model, change as you like

# ===== PAID OPTIONS =====
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3001
NODE_ENV=development
