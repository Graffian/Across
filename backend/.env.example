# Database (optional — extension works locally without it)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/across

# AI Providers
# You only need ONE of these:
ANTHROPIC_API_KEY=sk-ant-your-key-here     # For Claude chat + summarization
# OPENAI_API_KEY=sk-your-key-here          # Optional: for better embeddings

# Server
PORT=3001
NODE_ENV=development

# LLM Config
DEFAULT_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small
