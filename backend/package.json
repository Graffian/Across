    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrations.ts"
  },
  "dependencies": {
    "express": "4.18.2",
    "pg": "8.11.3",
    "pgvector": "0.1.8",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "@anthropic-ai/sdk": "0.20.0",
    "openai": "4.24.1",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "winston": "3.11.0",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/cors": "2.8.17",
    "@types/pg": "8.10.9",
    "@types/uuid": "9.0.7",
    "tsx": "4.7.0",
    "typescript": "5.3.3"
