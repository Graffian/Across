{
  "manifest_version": 3,
  "name": "Across - Browser Memory",
  "version": "0.2.0",
  "description": "Persistent AI memory for your browser. Indexes your tabs, lets you chat with everything you've seen.",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Across",
    "default_popup": "src/popup/index.html"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}
